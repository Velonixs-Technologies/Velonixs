@page "/about"
@model AboutModel
@{
    ViewData["Title"] = "About Us - Velonixs Technologies";
    ViewData["Description"] = "Learn about Velonixs Technologies, our mission, values, development process, and technology expertise.";
    ViewData["ActivePage"] = "About";
}

<section class="page-hero">
    <div class="container">
        <h1>@Model.PageContent.Hero.Title</h1>
        <p>@Model.PageContent.Hero.Description</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <span class="eyebrow text-primary">@Model.PageContent.Intro.Eyebrow</span>
                <h2 class="fw-bold mb-3">@Model.PageContent.Intro.Title</h2>
                @foreach (var paragraph in Model.PageContent.Intro.Paragraphs)
                {
                    <p class="@(paragraph == Model.PageContent.Intro.Paragraphs.First() ? "lead " : "")text-muted">@paragraph</p>
                }
                <p class="fw-bold mb-0">@Model.PageContent.Intro.Highlight</p>
            </div>
            <div class="col-lg-6">
                <img src="@Model.PageContent.Intro.ImageUrl" alt="@Model.PageContent.Intro.ImageAlt" class="rounded-3 shadow">
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.VisionHeading.Title</h2>
            <p>@Model.PageContent.VisionHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.VisionCards)
            {
                <div class="@card.ColumnClass">
                    <article class="@card.ArticleClass">
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.ValuesHeading.Title</h2>
            <p>@Model.PageContent.ValuesHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.ValueCards)
            {
                <div class="@card.ColumnClass">
                    <article class="@card.ArticleClass">
                        <span class="icon-box @card.IconClass" aria-hidden="true"></span>
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.ProcessHeading.Title</h2>
            <p>@Model.PageContent.ProcessHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var step in Model.PageContent.ProcessSteps)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="process-step">
                        <span class="step-number">@step.Number</span>
                        <h3>@step.Title</h3>
                        <p class="text-muted mb-0">@step.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.TechHeading.Title</h2>
            <p>@Model.PageContent.TechHeading.Description</p>
        </div>
        <div class="tech-grid">
            @foreach (var group in Model.PageContent.TechGroups)
            {
                <article class="tech-card">
                    <h3>@group.Title</h3>
                    <ul class="check-list">
                        @foreach (var item in group.Items)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>
            }
        </div>
    </div>
</section>

<section class="cta-band">
    <div class="container">
        <h2>@Model.PageContent.Cta.Title</h2>
        <p>@Model.PageContent.Cta.Description</p>
        <a href="@Model.PageContent.Cta.Action.Url" class="@Model.PageContent.Cta.Action.CssClass">@Model.PageContent.Cta.Action.Text</a>
    </div>
</section>
