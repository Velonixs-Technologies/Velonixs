@page "/terms-conditions"
@model TermsConditionsModel
@{
    ViewData["Title"] = "Terms & Conditions - Velonixs Technologies";
    ViewData["Description"] = "Terms and Conditions for using the Velonixs Technologies website.";
}

<section class="page-hero legal-hero">
    <div class="container">
        <span class="eyebrow">Website terms</span>
        <h1>Terms &amp; Conditions</h1>
        <p>The terms that apply when you browse this website, submit an enquiry, or use information published by Velonixs Technologies.</p>
    </div>
</section>

<section class="section legal-section">
    <div class="container">
        <div class="legal-intro">
            <div>
                <span class="eyebrow text-primary">Last updated</span>
                <h2>June 13, 2026</h2>
                <p>These terms are designed to make website use clear, fair, and predictable. Any paid services or project delivery work will be covered by a separate written agreement.</p>
            </div>
            <a href="/contact" class="btn btn-primary">Discuss a Project</a>
        </div>

        <div class="row g-4 legal-summary">
            <div class="col-md-4">
                <article class="legal-summary-card">
                    <span class="icon-box icon-trust" aria-hidden="true"></span>
                    <h3>Website Use</h3>
                    <p>Use this website lawfully and responsibly without disrupting its availability or security.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="legal-summary-card">
                    <span class="icon-box icon-quality" aria-hidden="true"></span>
                    <h3>Informational Content</h3>
                    <p>Website content explains our services but does not replace a signed project agreement.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="legal-summary-card">
                    <span class="icon-box icon-support" aria-hidden="true"></span>
                    <h3>Separate Engagements</h3>
                    <p>Client work, pricing, scope, timelines, and deliverables are confirmed separately in writing.</p>
                </article>
            </div>
        </div>

        <div class="legal-layout">
            <aside class="legal-toc" aria-label="Terms and conditions sections">
                <h3>On This Page</h3>
                <a href="#acceptance">Acceptance</a>
                <a href="#website-use">Use of Website</a>
                <a href="#content">Website Content</a>
                <a href="#enquiries">Enquiries</a>
                <a href="#intellectual-property">Intellectual Property</a>
                <a href="#liability">Liability</a>
                <a href="#changes">Changes</a>
            </aside>

            <article class="legal-content">
                <section id="acceptance" class="legal-card">
                    <h2>Acceptance of These Terms</h2>
                    <p>By accessing or using this website, you agree to these Terms &amp; Conditions. If you do not agree with these terms, please do not use the website.</p>
                    <p>These terms apply only to website use. Any commercial engagement with Velonixs Technologies, including software development, consulting, cloud services, modernization, or dedicated team services, will be subject to a separate proposal, statement of work, contract, or written agreement.</p>
                </section>

                <section id="website-use" class="legal-card">
                    <h2>Use of Website</h2>
                    <p>You agree to use this website in a lawful, respectful, and responsible manner. You must not attempt to damage the website, interfere with its operation, misuse forms, or access systems or data without permission.</p>
                    <ul class="check-list">
                        <li>Do not submit false, misleading, harmful, or unlawful information.</li>
                        <li>Do not attempt to bypass security controls or disrupt website availability.</li>
                        <li>Do not use the website to transmit spam, malicious code, or abusive content.</li>
                        <li>Do not copy, scrape, or reuse website content in a way that violates our rights.</li>
                    </ul>
                </section>

                <section id="content" class="legal-card">
                    <h2>Website Content and Service Information</h2>
                    <p>We make reasonable efforts to keep website information accurate and current, but the content is provided for general information only. Service descriptions, technology references, timelines, and capabilities may change over time.</p>
                    <p>Nothing on this website should be interpreted as a guaranteed result, fixed quote, legal advice, security certification, or binding offer. Formal scope, deliverables, commercial terms, ownership rights, confidentiality, and support commitments must be documented separately.</p>
                </section>

                <section id="enquiries" class="legal-card">
                    <h2>Enquiries and Communications</h2>
                    <p>Submitting a contact form, sending an email, or requesting a consultation does not create a client relationship or obligate Velonixs Technologies to accept a project. We may respond, request additional information, or decline enquiries at our discretion.</p>
                    <p>Please avoid submitting confidential, sensitive, proprietary, or regulated information through the website contact form unless we have already agreed in writing to receive it securely.</p>
                </section>

                <section id="intellectual-property" class="legal-card">
                    <h2>Intellectual Property</h2>
                    <p>The website design, text, branding, logo usage, images, layouts, service descriptions, and other content are owned by Velonixs Technologies or used with permission. You may view the website for personal or business evaluation, but you may not copy, reproduce, modify, distribute, or commercially reuse website materials without written permission.</p>
                    <p>Third-party trademarks, product names, technologies, and service names mentioned on this website belong to their respective owners.</p>
                </section>

                <section id="liability" class="legal-card">
                    <h2>Third-Party Links, Availability, and Liability</h2>
                    <p>This website may link to third-party websites or rely on third-party services for hosting, form processing, analytics, or infrastructure. We are not responsible for third-party content, availability, privacy practices, or service behavior.</p>
                    <p>To the fullest extent permitted by law, Velonixs Technologies is not liable for losses or damages arising from website use, temporary unavailability, errors, outdated information, third-party links, or reliance on website content.</p>
                </section>

                <section id="changes" class="legal-card">
                    <h2>Changes to These Terms</h2>
                    <p>We may update these Terms &amp; Conditions from time to time to reflect changes in our website, services, legal requirements, or business practices. The updated version will be posted on this page with a revised date.</p>
                    <p>For questions about these terms, contact us at <a href="mailto:info@velonixs.com">info@velonixs.com</a>.</p>
                </section>
            </article>
        </div>
    </div>
</section>
