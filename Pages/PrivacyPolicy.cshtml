@page "/privacy-policy"
@model PrivacyPolicyModel
@{
    ViewData["Title"] = "Privacy Policy - Velonixs Technologies";
    ViewData["Description"] = "Privacy Policy for Velonixs Technologies website visitors and enquiry form users.";
}

<section class="page-hero legal-hero">
    <div class="container">
        <span class="eyebrow">Legal information</span>
        <h1>Privacy Policy</h1>
        <p>How Velonixs Technologies handles information shared by website visitors, prospective clients, and people who submit enquiries through our contact form.</p>
    </div>
</section>

<section class="section legal-section">
    <div class="container">
        <div class="legal-intro">
            <div>
                <span class="eyebrow text-primary">Last updated</span>
                <h2>June 13, 2026</h2>
                <p>This policy explains what information we collect, why we collect it, how we use it, and how you can contact us about your privacy choices.</p>
            </div>
            <a href="/contact" class="btn btn-primary">Contact Us</a>
        </div>

        <div class="row g-4 legal-summary">
            <div class="col-md-4">
                <article class="legal-summary-card">
                    <span class="icon-box icon-email" aria-hidden="true"></span>
                    <h3>Enquiry Data</h3>
                    <p>We collect the details you choose to submit so our team can respond to your request.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="legal-summary-card">
                    <span class="icon-box icon-trust" aria-hidden="true"></span>
                    <h3>No Data Sales</h3>
                    <p>We do not sell personal information provided through this website.</p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="legal-summary-card">
                    <span class="icon-box icon-support" aria-hidden="true"></span>
                    <h3>Clear Contact</h3>
                    <p>You can contact us at any time about privacy questions or requests.</p>
                </article>
            </div>
        </div>

        <div class="legal-layout">
            <aside class="legal-toc" aria-label="Privacy policy sections">
                <h3>On This Page</h3>
                <a href="#information-we-collect">Information We Collect</a>
                <a href="#how-we-use-information">How We Use Information</a>
                <a href="#form-processing">Form Processing</a>
                <a href="#sharing-and-retention">Sharing &amp; Retention</a>
                <a href="#security-and-rights">Security &amp; Your Rights</a>
                <a href="#contact-privacy">Contact</a>
            </aside>

            <article class="legal-content">
                <section id="information-we-collect" class="legal-card">
                    <h2>Information We Collect</h2>
                    <p>Velonixs Technologies collects information that you voluntarily provide when you use our website or contact us about software development, cloud, modernization, or engineering team services.</p>
                    <ul class="check-list">
                        <li>Contact details such as your name, email address, phone number, and company name.</li>
                        <li>Project enquiry details such as service interest, business requirements, budget or timeline notes, and message content.</li>
                        <li>Communication records when you email us or continue a conversation after submitting a form.</li>
                        <li>Basic technical information that may be collected by hosting, analytics, security, or form-processing tools, such as browser type, approximate location, IP address, and device information.</li>
                    </ul>
                </section>

                <section id="how-we-use-information" class="legal-card">
                    <h2>How We Use Information</h2>
                    <p>We use submitted information to understand your request and communicate with you in a practical, professional way. Our use of information is limited to business purposes connected with our services and website operations.</p>
                    <ul class="check-list">
                        <li>Respond to enquiries and schedule follow-up discussions.</li>
                        <li>Understand project needs, technical requirements, and possible engagement models.</li>
                        <li>Prepare proposals, estimates, discovery notes, or service recommendations.</li>
                        <li>Improve website content, user experience, and communication quality.</li>
                        <li>Protect our website, systems, business interests, and users from misuse or spam.</li>
                    </ul>
                </section>

                <section id="form-processing" class="legal-card">
                    <h2>Form Processing and Third-Party Services</h2>
                    <p>Our contact form may use a third-party form processing service to securely deliver your enquiry to our business email inbox. These services process form submissions on our behalf and may handle submitted details only as needed to provide their service.</p>
                    <p>We may also use third-party services for hosting, DNS, security, performance monitoring, or analytics. Each service may process limited technical information according to its own terms and privacy practices.</p>
                </section>

                <section id="sharing-and-retention" class="legal-card">
                    <h2>Data Sharing and Retention</h2>
                    <p>We do not sell your personal information. We may share information only when it is reasonably necessary for legitimate business operations, responding to your request, complying with law, or protecting our rights.</p>
                    <ul class="check-list">
                        <li>With service providers that help operate our website or process enquiries.</li>
                        <li>With internal team members or delivery partners who need the information to evaluate your request.</li>
                        <li>When required by law, regulation, court order, or a lawful government request.</li>
                        <li>When necessary to protect against fraud, abuse, security risks, or legal claims.</li>
                    </ul>
                    <p>We keep enquiry information only for as long as reasonably needed for business communication, project evaluation, recordkeeping, legal compliance, or dispute prevention.</p>
                </section>

                <section id="security-and-rights" class="legal-card">
                    <h2>Security and Your Rights</h2>
                    <p>We take reasonable steps to protect information submitted through this website. However, no website, email system, or internet transmission can be guaranteed to be completely secure.</p>
                    <p>Depending on your location and applicable law, you may have the right to request access, correction, deletion, restriction, or a copy of personal information you submitted. We will review reasonable requests and respond as required by applicable law.</p>
                </section>

                <section id="contact-privacy" class="legal-card legal-contact-card">
                    <h2>Privacy Contact</h2>
                    <p>For privacy questions, correction requests, or deletion requests, contact Velonixs Technologies at <a href="mailto:info@velonixs.com">info@velonixs.com</a>.</p>
                    <a href="mailto:info@velonixs.com" class="btn btn-primary">Email Us</a>
                </section>
            </article>
        </div>
    </div>
</section>
