@page "/contact"
@model ContactModel
@{
    ViewData["Title"] = "Contact Us - Velonixs Technologies";
    ViewData["Description"] = "Contact Velonixs Technologies to discuss your software development, cloud, modernization, or dedicated engineering team needs.";
    ViewData["ActivePage"] = "Contact";
}

<section class="page-hero">
    <div class="container">
        <h1>@Model.PageContent.Hero.Title</h1>
        <p>@Model.PageContent.Hero.Description</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.ReachHeading.Title</h2>
            <p>@Model.PageContent.ReachHeading.Description</p>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var method in Model.PageContent.ContactMethods)
            {
                <div class="col-md-4">
                    <article class="contact-card text-center">
                        <span class="icon-box @method.IconClass" aria-hidden="true"></span>
                        <h3>@method.Title</h3>
                        @if (!string.IsNullOrWhiteSpace(method.Url))
                        {
                            <p><a href="@method.Url">@method.PrimaryText</a></p>
                        }
                        else if (method.IsStrong)
                        {
                            <p class="fw-bold">@method.PrimaryText</p>
                        }
                        else
                        {
                            <p>@method.PrimaryText</p>
                        }
                        <p class="small">@method.SecondaryText</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="row g-5 align-items-start">
            <div class="col-lg-5">
                <span class="eyebrow text-primary">@Model.PageContent.FormEyebrow</span>
                <h2 class="fw-bold mb-3">@Model.PageContent.FormTitle</h2>
                <p class="lead text-muted">@Model.PageContent.FormDescription</p>
                <div class="row g-3 mt-2">
                    @foreach (var card in Model.PageContent.FormHighlights)
                    {
                        <div class="@card.ColumnClass">
                            <article class="@card.ArticleClass">
                                <h3>@card.Title</h3>
                                <p>@card.Description</p>
                            </article>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-7">
                <form id="contactForm" class="contact-form needs-validation" action="https://api.web3forms.com/submit" method="POST" novalidate>
                    <input type="hidden" name="access_key" value="7d1ef463-2f0f-4b9b-8a73-9875eba8b8da">
                    <input type="hidden" name="subject" value="New Velonixs website enquiry">
                    <input type="hidden" name="redirect" value="https://velonixs.com/?submitted=true">
                    <input type="checkbox" name="botcheck" class="d-none" tabindex="-1" autocomplete="off">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="name" class="form-label fw-bold">Full Name *</label>
                            <input type="text" class="form-control" id="name" name="name" required placeholder="Your full name">
                            <div class="invalid-feedback">Please enter your name.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="email" class="form-label fw-bold">Email Address *</label>
                            <input type="email" class="form-control" id="email" name="email" required placeholder="you@example.com">
                            <div class="invalid-feedback">Please enter a valid email.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="phone" class="form-label fw-bold">Phone Number</label>
                            <input type="tel" class="form-control" id="phone" name="phone" placeholder="+1 (555) 123-4567">
                        </div>
                        <div class="col-md-6">
                            <label for="company" class="form-label fw-bold">Company Name</label>
                            <input type="text" class="form-control" id="company" name="company" placeholder="Your company">
                        </div>
                        <div class="col-12">
                            <label for="service" class="form-label fw-bold">Service of Interest *</label>
                            <select class="form-select" id="service" name="service" required>
                                <option value="">Select a service</option>
                                @foreach (var option in Model.PageContent.ServiceOptions)
                                {
                                    <option value="@option.Value">@option.Text</option>
                                }
                            </select>
                            <div class="invalid-feedback">Please choose a service.</div>
                        </div>
                        <div class="col-12">
                            <label for="message" class="form-label fw-bold">Message *</label>
                            <textarea class="form-control" id="message" name="message" rows="5" required placeholder="Tell us about your project..."></textarea>
                            <div class="invalid-feedback">Please share a short message.</div>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="agree" name="agree" required>
                                <label class="form-check-label" for="agree">I agree to the <a href="/privacy-policy">privacy policy</a> and <a href="/terms-conditions">terms &amp; conditions</a>.</label>
                                <div class="invalid-feedback">Please confirm before submitting.</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary btn-lg w-100">Send Message</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.WhyHeading.Title</h2>
            <p>@Model.PageContent.WhyHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.WhyCards)
            {
                <div class="@card.ColumnClass">
                    <article class="@card.ArticleClass">
                        <span class="icon-box @card.IconClass" aria-hidden="true"></span>
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.FaqHeading.Title</h2>
            <p>@Model.PageContent.FaqHeading.Description</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="accordion" id="faqAccordion">
                    @for (var index = 0; index < Model.PageContent.Faqs.Count; index++)
                    {
                        var faq = Model.PageContent.Faqs[index];
                        var isFirst = index == 0;
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#@faq.Id" aria-expanded="@(isFirst.ToString().ToLowerInvariant())" aria-controls="@faq.Id">
                                    @faq.Question
                                </button>
                            </h2>
                            <div id="@faq.Id" class="accordion-collapse collapse @(isFirst ? "show" : "")" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">@faq.Answer</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-band">
    <div class="container">
        <h2>@Model.PageContent.Cta.Title</h2>
        <p>@Model.PageContent.Cta.Description</p>
        <a href="@Model.PageContent.Cta.Action.Url" class="@Model.PageContent.Cta.Action.CssClass">@Model.PageContent.Cta.Action.Text</a>
    </div>
</section>
