@{
    var title = ViewData["Title"] as string ?? "Velonixs";
    var description = ViewData["Description"] as string ?? "Global software development and IT services company specializing in custom software solutions and cloud technologies.";
    var activePage = ViewData["ActivePage"] as string ?? "";
}
@inject Velonixs.Services.SiteContentService Content
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <meta name="description" content="@description" />
    <link rel="icon" href="~/assets/images/logo-nav.png" type="image/png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/assets/images/logo-nav.png" asp-append-version="true" alt="Velonixs logo" class="brand-logo">
                <span class="brand-name">Velonixs</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto align-items-lg-center">
                    @foreach (var link in Content.NavigationLinks)
                    {
                        var activeName = link.Text == "About Us" ? "About" : link.Text;
                        <a class="nav-link @(activePage == activeName ? "active" : "")" href="@link.Url">@link.Text</a>
                    }
                    <a class="btn btn-primary ms-lg-3 mt-2 mt-lg-0" href="/contact">Get Started</a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <h5>Velonixs Technologies</h5>
                    <p>Global software development and IT services company specializing in custom software solutions and cloud technologies.</p>
                    <p>Headquartered in India | Serving Clients Globally</p>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        @foreach (var link in Content.FooterQuickLinks)
                        {
                            <li class="mb-2"><a href="@link.Url">@link.Text</a></li>
                        }
                    </ul>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h5>Services</h5>
                    <ul class="list-unstyled">
                        @foreach (var link in Content.FooterServiceLinks)
                        {
                            <li class="mb-2"><a href="@link.Url">@link.Text</a></li>
                        }
                    </ul>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h5>Contact Info</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">Email: <a href="mailto:info@velonixs.com">info@velonixs.com</a></li>
                        <li class="mb-2">Website: <a href="https://velonixs.com">velonixs.com</a></li>
                        <li class="mt-3"><a href="https://www.linkedin.com/company/velonixs-technologies/" target="_blank" rel="noopener noreferrer">LinkedIn</a> | <a href="#">Twitter</a> | <a href="#">Facebook</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Velonixs Technologies. All rights reserved. | <a href="/privacy-policy">Privacy Policy</a> | <a href="/terms-conditions">Terms &amp; Conditions</a></p>
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
