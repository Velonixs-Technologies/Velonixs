@page
@model IndexModel
@{
    ViewData["Title"] = "Velonixs - Software Development & IT Services";
    ViewData["Description"] = "Velonixs Technologies builds custom software, cloud platforms, web applications, and dedicated engineering teams for growing businesses.";
    ViewData["ActivePage"] = "Home";
}

<section class="hero">
    <div class="container">
        <div class="hero-content">
            <span class="eyebrow">@Model.PageContent.Hero.Eyebrow</span>
            <h1>@Model.PageContent.Hero.Title</h1>
            <p>@Model.PageContent.Hero.Description</p>
            <div class="hero-actions">
                @foreach (var action in Model.PageContent.Hero.Actions)
                {
                    <a href="@action.Url" class="@action.CssClass">@action.Text</a>
                }
            </div>
        </div>
        <div class="hero-stats" aria-label="Velonixs delivery highlights">
            @foreach (var stat in Model.PageContent.Hero.Stats)
            {
                <div class="stat">
                    <strong>@stat.Value</strong>
                    <span>@stat.Label</span>
                </div>
            }
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.WhyHeading.Title</h2>
            <p>@Model.PageContent.WhyHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.WhyCards)
            {
                <div class="@card.ColumnClass">
                    <article class="@card.ArticleClass">
                        <span class="icon-box @card.IconClass" aria-hidden="true"></span>
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.ServicesHeading.Title</h2>
            <p>@Model.PageContent.ServicesHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.ServiceCards)
            {
                <div class="@card.ColumnClass">
                    <article class="@card.ArticleClass">
                        <span class="icon-box @card.IconClass" aria-hidden="true"></span>
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </article>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a href="/services" class="btn btn-primary">View All Services</a>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.TechHeading.Title</h2>
            <p>@Model.PageContent.TechHeading.Description</p>
        </div>
        <div class="tech-grid">
            @foreach (var group in Model.PageContent.TechGroups)
            {
                <article class="tech-card">
                    <h3>@group.Title</h3>
                    <ul class="check-list">
                        @foreach (var item in group.Items)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>
            }
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.IndustriesHeading.Title</h2>
            <p>@Model.PageContent.IndustriesHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.IndustryCards)
            {
                <div class="@card.ColumnClass">
                    <article class="@card.ArticleClass">
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="cta-band">
    <div class="container">
        <h2>@Model.PageContent.Cta.Title</h2>
        <p>@Model.PageContent.Cta.Description</p>
        <a href="@Model.PageContent.Cta.Action.Url" class="@Model.PageContent.Cta.Action.CssClass">@Model.PageContent.Cta.Action.Text</a>
    </div>
</section>
