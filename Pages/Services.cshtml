@page "/services"
@model ServicesModel
@{
    ViewData["Title"] = "Our Services - Velonixs Technology";
    ViewData["Description"] = "Explore Velonixs services including custom software development, web applications, .NET development, Azure cloud solutions, modernization, and staff augmentation.";
    ViewData["ActivePage"] = "Services";
}

<section class="page-hero">
    <div class="container">
        <h1>@Model.PageContent.Hero.Title</h1>
        <p>@Model.PageContent.Hero.Description</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-heading">
            <h2>@Model.PageContent.OfferHeading.Title</h2>
            <p>@Model.PageContent.OfferHeading.Description</p>
        </div>
        <div class="row g-4">
            @foreach (var card in Model.PageContent.OfferCards)
            {
                <div class="@card.ColumnClass">
                    <a class="@card.ArticleClass" href="@card.Url">
                        <span class="icon-box @card.IconClass" aria-hidden="true"></span>
                        <h3>@card.Title</h3>
                        <p>@card.Description</p>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section class="service-strip">
    <div class="container">
        @foreach (var service in Model.PageContent.ServiceDetails)
        {
            <div id="@service.Id" class="row g-4 service-row">
                <div class="col-lg-6 @(service.Reverse ? "order-lg-2" : "")">
                    <span class="eyebrow text-primary">@service.Eyebrow</span>
                    <h2 class="fw-bold mb-3">@service.Title</h2>
                    <p class="lead text-muted">@service.Description</p>
                    <div class="row">
                        @foreach (var list in service.Lists)
                        {
                            <div class="col-md-6">
                                <h5 class="fw-bold mt-4">@list.Title</h5>
                                <ul class="check-list">
                                    @foreach (var item in list.Items)
                                    {
                                        <li>@item</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-lg-6 @(service.Reverse ? "order-lg-1" : "")">
                    <div class="service-visual d-flex flex-column justify-content-end">
                        <span>@service.VisualTitle</span>
                        <span class="visual-icon @service.IconClass" aria-hidden="true"></span>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="cta-band">
    <div class="container">
        <h2>@Model.PageContent.Cta.Title</h2>
        <p>@Model.PageContent.Cta.Description</p>
        <a href="@Model.PageContent.Cta.Action.Url" class="@Model.PageContent.Cta.Action.CssClass">@Model.PageContent.Cta.Action.Text</a>
    </div>
</section>
